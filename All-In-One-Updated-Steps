  --region "$AWS_REGION" \
  --query "agentSummaries[?agentName=='opsai-assistant-agent'].agentId | [0]" \
  --output text)

if [[ -z "$AGENT_ID" || "$AGENT_ID" == "None" ]]; then
  echo "ERROR: Agent opsai-assistant-agent was not found."
