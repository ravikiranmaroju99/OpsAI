ALIAS_ID=$(aws bedrock-agent list-agent-aliases \
  --agent-id "$AGENT_ID" \
  --region "$AWS_REGION" \
  --query "agentAliasSummaries[?agentAliasName=='opsai-mvp'].agentAliasId | [0]" \
  --output text)

if [[ -z "$ALIAS_ID" || "$ALIAS_ID" == "None" ]]; then
  echo "ERROR: Alias opsai-mvp was not found."
  exit 1
