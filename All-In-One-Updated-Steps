#!/usr/bin/env bash
set -euo pipefail

cd "$HOME/opsai-assistant-aws"

if [[ ! -f .env ]]; then
  echo "ERROR: $HOME/opsai-assistant-aws/.env was not found."
  exit 1
fi

set -a
source .env
set +a

required_vars=(AWS_REGION AMPLIFY_APP_ID AMPLIFY_BRANCH_NAME AMPLIFY_URL)
