echo "Agent ID: $AGENT_ID"
echo "Alias ID: $ALIAS_ID"

aws bedrock-agent get-agent-alias \
  --agent-id "$AGENT_ID" \
  --agent-alias-id "$ALIAS_ID" \
  --region "$AWS_REGION" \
  --query 'agentAlias.{AliasName:agentAliasName,AliasID:agentAliasId,Status:agentAliasStatus,Routing:routingConfiguration}' \
