  --api-id "$API_ID" \
  --region "$AWS_REGION" \
  --query "Items[?StageName=='\$default'].StageName | [0]" \
  --output text)

if [[ -z "$STAGE_NAME" || "$STAGE_NAME" == "None" ]]; then
  aws apigatewayv2 create-stage \
    --api-id "$API_ID" \
    --stage-name '$default' \
    --auto-deploy \
    --region "$AWS_REGION" \
    >/dev/null
