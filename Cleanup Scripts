#!/usr/bin/env bash
set -Eeuo pipefail

export AWS_PAGER=""
export AWS_CLI_AUTO_PROMPT=off

PROJECT_DIR="${HOME}/opsai-assistant-aws"
ENV_FILE="${PROJECT_DIR}/.env"
DEFAULT_EXPECTED_ACCOUNT_ID="845482522818"
MODE="${1:-preview}"
STATE_FILE_INPUT="${2:-}"

AWS_REGION="${AWS_REGION:-us-east-1}"
AWS_DEFAULT_REGION="${AWS_DEFAULT_REGION:-$AWS_REGION}"
export AWS_REGION AWS_DEFAULT_REGION

AGENT_NAME="opsai-assistant-agent"
ALIAS_NAME="opsai-mvp"
KB_NAME="opsai-assistant-kb"
DATA_SOURCE_NAME="opsai-runbooks-s3"
LAMBDA_FUNCTION_NAME="${LAMBDA_FUNCTION_NAME:-opsai-assistant-api}"
LAMBDA_ROLE_NAME="OpsAILambdaExecutionRole"
API_NAME="opsai-assistant-http-api"
AMPLIFY_APP_NAME="opsai-assistant-ui"
LOG_GROUP="/aws/lambda/${LAMBDA_FUNCTION_NAME}"

TIMESTAMP="$(date +%Y%m%d-%H%M%S)"
PREVIEW_REPORT="${HOME}/opsai-cleanup-preview-${TIMESTAMP}.txt"
LOG_FILE="${HOME}/opsai-cleanup-${TIMESTAMP}.log"
STATE_FILE="${HOME}/opsai-cleanup-state-${TIMESTAMP}.tsv"
TEMP_DIR=""
FAILURES=0
WARNINGS=0

usage() {
  cat <<'USAGE'
OpsAI Assistant complete AWS cleanup

Usage:
  bash opsai_aws_complete_cleanup_all_in_one_final.sh preview
  bash opsai_aws_complete_cleanup_all_in_one_final.sh delete
  bash opsai_aws_complete_cleanup_all_in_one_final.sh verify [state-file]

Modes:
  preview  Read-only inventory. This is the default and deletes nothing.
  delete   Permanently deletes the named OpsAI AWS resources after confirmation.
  verify   Confirms that the project resources no longer exist.

Safety:
  The script is locked to AWS account 845482522818 by default.
  To use an intentional different account, set:
    OPSAI_EXPECTED_ACCOUNT_ID=<account-id>
USAGE
}

cleanup_temp() {
  if [[ -n "${TEMP_DIR:-}" && -d "$TEMP_DIR" ]]; then
    rm -rf "$TEMP_DIR"
  fi
}
trap cleanup_temp EXIT

on_error() {
  local line_number="$1"
  local exit_code="$2"
  echo
  echo "ERROR: Script stopped at line ${line_number} with exit code ${exit_code}." >&2
  echo "Review the most recent output and rerun preview or verify." >&2
}
trap 'on_error "$LINENO" "$?"' ERR

valid_value() {
  [[ -n "${1:-}" && "$1" != "None" && "$1" != "null" && "$1" != "NOT_FOUND" ]]
}

warn() {
  WARNINGS=$((WARNINGS + 1))
  echo "WARNING: $*" >&2
}

failure() {
  FAILURES=$((FAILURES + 1))
  echo "ERROR: $*" >&2
}

require_command() {
  local name="$1"
  if ! command -v "$name" >/dev/null 2>&1; then
    echo "ERROR: Required command is not installed: $name" >&2
    exit 1
  fi
}

aws_text_list() {
  # Convert AWS CLI text output (tabs/newlines) into one non-empty item per line.
  tr '\t' '\n' | sed '/^[[:space:]]*$/d; /^None$/d; /^null$/d'
}

append_state() {
  local type="$1"
  local value="${2:-}"
  if valid_value "$value"; then
    printf '%s\t%s\n' "$type" "$value" >> "$STATE_FILE"
  fi
}

account_guard() {
  local expected_account_id="${OPSAI_EXPECTED_ACCOUNT_ID:-$DEFAULT_EXPECTED_ACCOUNT_ID}"

  ACCOUNT_ID="$(aws sts get-caller-identity --query Account --output text)"
  CURRENT_ARN="$(aws sts get-caller-identity --query Arn --output text)"

  if [[ "$ACCOUNT_ID" != "$expected_account_id" ]]; then
    cat >&2 <<EOF_ACCOUNT
ERROR: AWS account safety check failed.
Expected account: $expected_account_id
Current account : $ACCOUNT_ID
Current identity: $CURRENT_ARN

No resources were changed.
Only when this is intentionally the correct account, rerun with:
  OPSAI_EXPECTED_ACCOUNT_ID=$ACCOUNT_ID bash $0 $MODE
EOF_ACCOUNT
    exit 1
  fi
}

load_environment() {
  if [[ -f "$ENV_FILE" ]]; then
    set -a
    # shellcheck disable=SC1090
    source "$ENV_FILE"
    set +a
  fi

  AWS_REGION="${AWS_REGION:-us-east-1}"
  AWS_DEFAULT_REGION="${AWS_DEFAULT_REGION:-$AWS_REGION}"
  export AWS_REGION AWS_DEFAULT_REGION

  KNOWLEDGE_BUCKET="${OPSAI_BUCKET:-opsai-assistant-kb-${ACCOUNT_ID}-${AWS_REGION}}"
}

collect_inventory() {
  mapfile -t AMPLIFY_APP_IDS < <(
    aws amplify list-apps \
      --region "$AWS_REGION" \
      --query "apps[?name=='${AMPLIFY_APP_NAME}'].appId" \
      --output text 2>/dev/null | aws_text_list || true
  )

  mapfile -t API_IDS < <(
    aws apigatewayv2 get-apis \
      --region "$AWS_REGION" \
      --query "Items[?Name=='${API_NAME}'].ApiId" \
      --output text 2>/dev/null | aws_text_list || true
  )

  mapfile -t AGENT_IDS < <(
    aws bedrock-agent list-agents \
      --region "$AWS_REGION" \
      --query "agentSummaries[?agentName=='${AGENT_NAME}'].agentId" \
      --output text 2>/dev/null | aws_text_list || true
  )

  mapfile -t KB_IDS < <(
    aws bedrock-agent list-knowledge-bases \
      --region "$AWS_REGION" \
      --query "knowledgeBaseSummaries[?name=='${KB_NAME}'].knowledgeBaseId" \
      --output text 2>/dev/null | aws_text_list || true
  )

  LAMBDA_EXISTS="false"
  if aws lambda get-function \
    --function-name "$LAMBDA_FUNCTION_NAME" \
    --region "$AWS_REGION" >/dev/null 2>&1; then
    LAMBDA_EXISTS="true"
  fi

  LOG_GROUP_EXISTS="false"
  if [[ "$(aws logs describe-log-groups \
      --log-group-name-prefix "$LOG_GROUP" \
      --region "$AWS_REGION" \
      --query "length(logGroups[?logGroupName=='${LOG_GROUP}'])" \
      --output text 2>/dev/null || echo 0)" != "0" ]]; then
    LOG_GROUP_EXISTS="true"
  fi

  BUCKET_EXISTS="false"
  if aws s3api head-bucket --bucket "$KNOWLEDGE_BUCKET" >/dev/null 2>&1; then
    BUCKET_EXISTS="true"
  fi

  LAMBDA_ROLE_EXISTS="false"
  if aws iam get-role --role-name "$LAMBDA_ROLE_NAME" >/dev/null 2>&1; then
    LAMBDA_ROLE_EXISTS="true"
  fi

  declare -gA ROLE_NAMES=()
  declare -gA VECTOR_INDEX_ARNS=()
  declare -gA VECTOR_BUCKET_ARNS=()

  ROLE_NAMES["$LAMBDA_ROLE_NAME"]=1

  if valid_value "${LAMBDA_ROLE_ARN:-}"; then
    ROLE_NAMES["${LAMBDA_ROLE_ARN##*/}"]=1
  fi
  if valid_value "${AGENT_ROLE_ARN:-}"; then
    ROLE_NAMES["${AGENT_ROLE_ARN##*/}"]=1
  fi
  if valid_value "${KB_ROLE_ARN:-}"; then
    ROLE_NAMES["${KB_ROLE_ARN##*/}"]=1
  fi

  for agent_id in "${AGENT_IDS[@]:-}"; do
    [[ -z "$agent_id" ]] && continue

    local agent_role_arn
    agent_role_arn="$(aws bedrock-agent get-agent \
      --agent-id "$agent_id" \
      --region "$AWS_REGION" \
      --query 'agent.agentResourceRoleArn' \
      --output text 2>/dev/null || true)"

    if valid_value "$agent_role_arn"; then
      ROLE_NAMES["${agent_role_arn##*/}"]=1
    fi
  done

  for kb_id in "${KB_IDS[@]:-}"; do
    [[ -z "$kb_id" ]] && continue

    local kb_json kb_role_arn vector_index_arn vector_bucket_arn
    kb_json="$(aws bedrock-agent get-knowledge-base \
      --knowledge-base-id "$kb_id" \
      --region "$AWS_REGION" \
      --output json 2>/dev/null || true)"

    [[ -z "$kb_json" ]] && continue

    kb_role_arn="$(python3 -c 'import json,sys; d=json.load(sys.stdin); print(d.get("knowledgeBase",{}).get("roleArn", ""))' <<<"$kb_json" 2>/dev/null || true)"
    vector_index_arn="$(python3 -c 'import json,sys; d=json.load(sys.stdin); print(d.get("knowledgeBase",{}).get("storageConfiguration",{}).get("s3VectorsConfiguration",{}).get("indexArn", ""))' <<<"$kb_json" 2>/dev/null || true)"
    vector_bucket_arn="$(python3 -c 'import json,sys; d=json.load(sys.stdin); print(d.get("knowledgeBase",{}).get("storageConfiguration",{}).get("s3VectorsConfiguration",{}).get("vectorBucketArn", ""))' <<<"$kb_json" 2>/dev/null || true)"

    if valid_value "$kb_role_arn"; then
      ROLE_NAMES["${kb_role_arn##*/}"]=1
    fi
    if valid_value "$vector_index_arn"; then
      VECTOR_INDEX_ARNS["$vector_index_arn"]=1
    fi
    if valid_value "$vector_bucket_arn"; then
      VECTOR_BUCKET_ARNS["$vector_bucket_arn"]=1
    fi
  done
}

