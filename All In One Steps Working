Step 16B — Create the Amplify Hosting Application

Amplify static applications use platform type WEB. We will create a manually deployed application without connecting GitHub.

Run:

cd ~/opsai-assistant-aws

set -a
source .env
set +a

AMPLIFY_APP_NAME="opsai-assistant-ui"
AMPLIFY_BRANCH_NAME="main"

# Create a ZIP with index.html at the root
rm -f app/opsai-assistant-ui.zip

cd app/web
zip -qr ../opsai-assistant-ui.zip .
cd ../..

echo "Frontend deployment package:"
unzip -l app/opsai-assistant-ui.zip

# Find an existing Amplify application
AMPLIFY_APP_ID=$(aws amplify list-apps \
  --region "$AWS_REGION" \
  --query "apps[?name=='$AMPLIFY_APP_NAME'].appId | [0]" \
  --output text)

# Create the application when it does not exist
if [[ -z "$AMPLIFY_APP_ID" || "$AMPLIFY_APP_ID" == "None" ]]; then
    echo "Creating Amplify application..."

    AMPLIFY_APP_ID=$(aws amplify create-app \
      --name "$AMPLIFY_APP_NAME" \
      --description \
      "Browser interface for the OpsAI Assistant AWS MVP" \
      --platform WEB \
      --no-enable-branch-auto-build \
      --region "$AWS_REGION" \
      --query 'app.appId' \
      --output text)
else
    echo "Using existing Amplify application: $AMPLIFY_APP_ID"
fi

# Check whether the main branch exists
if ! aws amplify get-branch \
  --app-id "$AMPLIFY_APP_ID" \
  --branch-name "$AMPLIFY_BRANCH_NAME" \
  --region "$AWS_REGION" >/dev/null 2>&1
then
    echo "Creating Amplify main branch..."

    aws amplify create-branch \
      --app-id "$AMPLIFY_APP_ID" \
      --branch-name "$AMPLIFY_BRANCH_NAME" \
      --description "OpsAI MVP production branch" \
      --stage PRODUCTION \
      --framework "Web" \
      --no-enable-auto-build \
      --region "$AWS_REGION" \
      >/dev/null
else
    echo "Amplify main branch already exists."
fi

DEFAULT_DOMAIN=$(aws amplify get-app \
  --app-id "$AMPLIFY_APP_ID" \
  --region "$AWS_REGION" \
  --query 'app.defaultDomain' \
  --output text)

AMPLIFY_URL="https://${AMPLIFY_BRANCH_NAME}.${DEFAULT_DOMAIN}"

if grep -q '^AMPLIFY_APP_ID=' .env; then
    sed -i \
      "s/^AMPLIFY_APP_ID=.*/AMPLIFY_APP_ID=$AMPLIFY_APP_ID/" \
      .env
else
    echo "AMPLIFY_APP_ID=$AMPLIFY_APP_ID" >> .env
fi

if grep -q '^AMPLIFY_BRANCH_NAME=' .env; then
    sed -i \
      "s/^AMPLIFY_BRANCH_NAME=.*/AMPLIFY_BRANCH_NAME=$AMPLIFY_BRANCH_NAME/" \
      .env
else
    echo "AMPLIFY_BRANCH_NAME=$AMPLIFY_BRANCH_NAME" >> .env
fi

if grep -q '^AMPLIFY_URL=' .env; then
    sed -i \
      "s|^AMPLIFY_URL=.*|AMPLIFY_URL=$AMPLIFY_URL|" \
      .env
else
    echo "AMPLIFY_URL=$AMPLIFY_URL" >> .env
fi

echo
echo "Amplify App ID: $AMPLIFY_APP_ID"
echo "Branch: $AMPLIFY_BRANCH_NAME"
echo "Planned website URL: $AMPLIFY_URL"
Step 16C — Deploy the Chatbot UI

For a manual Amplify deployment, create-deployment returns a ZIP upload URL and a job ID. After uploading the ZIP, start-deployment starts the hosting job.

Run:

cd ~/opsai-assistant-aws

set -a
source .env
set +a

DEPLOYMENT_OUTPUT=$(aws amplify create-deployment \
  --app-id "$AMPLIFY_APP_ID" \
  --branch-name "$AMPLIFY_BRANCH_NAME" \
  --region "$AWS_REGION" \
  --output json)

JOB_ID=$(echo "$DEPLOYMENT_OUTPUT" | python3 -c \
  'import json,sys; print(json.load(sys.stdin)["jobId"])')

UPLOAD_URL=$(echo "$DEPLOYMENT_OUTPUT" | python3 -c \
  'import json,sys; print(json.load(sys.stdin)["zipUploadUrl"])')

echo "Deployment job ID: $JOB_ID"
echo "Uploading frontend package..."

curl -sS \
  --upload-file app/opsai-assistant-ui.zip \
  "$UPLOAD_URL"

echo
echo "Starting Amplify deployment..."

aws amplify start-deployment \
  --app-id "$AMPLIFY_APP_ID" \
  --branch-name "$AMPLIFY_BRANCH_NAME" \
  --job-id "$JOB_ID" \
  --region "$AWS_REGION" \
  >/dev/null

echo "Waiting for deployment to complete..."

while true
do
    DEPLOYMENT_STATUS=$(aws amplify get-job \
      --app-id "$AMPLIFY_APP_ID" \
      --branch-name "$AMPLIFY_BRANCH_NAME" \
      --job-id "$JOB_ID" \
      --region "$AWS_REGION" \
      --query 'job.summary.status' \
      --output text)

    echo "Deployment status: $DEPLOYMENT_STATUS"

    case "$DEPLOYMENT_STATUS" in
        SUCCEED)
            break
            ;;
        FAILED|CANCELLED)
            echo "Amplify deployment failed."
            exit 1
            ;;
        *)
            sleep 10
            ;;
    esac
done

echo
echo "OpsAI chatbot URL:"
echo "$AMPLIFY_URL"

